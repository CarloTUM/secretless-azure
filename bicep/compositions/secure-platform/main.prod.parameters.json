{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location":                 { "value": "westeurope" },
    "environment":              { "value": "prod"       },
    "namePrefix":               { "value": "contoso"    },
    "allowPublicNetworkAccess": { "value": false        },
    "enableDefenderForCloud":   { "value": true         },
    "logRetentionDays":         { "value": 180          },
    "kvPurgeProtection":        { "value": true         },

    "vnetAddressPrefixes":         { "value": ["10.30.0.0/16"] },
    "privateEndpointSubnetPrefix": { "value": "10.30.0.0/24"   },
    "workloadSubnetPrefix":        { "value": "10.30.1.0/24"   },

    "tags": {
      "value": {
        "platform": "secure",
        "env":      "prod"
      }
    }
  }
}
